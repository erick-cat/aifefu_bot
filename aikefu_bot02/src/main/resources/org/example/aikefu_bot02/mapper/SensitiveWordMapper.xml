<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.aikefu_bot02.mapper.SensitiveWordMapper">

    <resultMap id="BaseResultMap" type="org.example.aikefu_bot02.entity.SensitiveWord">
            <id property="id" column="id" />
            <result property="word" column="word" />
            <result property="category" column="category" />
            <result property="level" column="level" />
            <result property="action" column="action" />
            <result property="replaceTo" column="replace_to" />
            <result property="status" column="status" />
            <result property="createdAt" column="created_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id,word,category,level,action,replace_to,
        status,created_at
    </sql>
</mapper>
